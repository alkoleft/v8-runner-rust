{
  "$defs": {
    "BuildSchema": {
      "additionalProperties": false,
      "properties": {
        "dynamicUpdate": {
          "description": "Default `/UpdateDBCfg -Dynamic+` toggle for `build`. CLI `--dynamic` overrides this.",
          "type": "boolean"
        },
        "partialLoadThreshold": {
          "description": "Maximum changed-file count for partial Designer load before falling back to full load.",
          "format": "uint",
          "minimum": 1,
          "type": "integer"
        }
      },
      "type": "object"
    },
    "BuilderBackendSchema": {
      "enum": [
        "DESIGNER",
        "IBCMD"
      ],
      "type": "string"
    },
    "ClientMcpToolSchema": {
      "additionalProperties": false,
      "properties": {
        "extension": {
          "anyOf": [
            {
              "$ref": "#/$defs/ToolExtensionSchema"
            },
            {
              "type": "null"
            }
          ],
          "description": "Optional tool extension prepared by `build` for client MCP launches."
        },
        "port": {
          "description": "Default port passed to onec-client-mcp-devkit.",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 1,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "EdtCliSchema": {
      "additionalProperties": false,
      "properties": {
        "auto-start": {
          "description": "Eagerly prewarm the shared EDT session on MCP server startup.",
          "type": "boolean"
        },
        "command_timeout_ms": {
          "description": "Default timeout for interactive EDT commands, in milliseconds.",
          "format": "uint64",
          "minimum": 1,
          "type": "integer"
        },
        "interactive-mode": {
          "description": "Use long-lived interactive `1cedtcli` processes instead of one-shot invocations.",
          "type": "boolean"
        },
        "path": {
          "description": "Path to `1cedtcli`, EDT installation root, or version-like discovery hint.",
          "type": [
            "string",
            "null"
          ]
        },
        "startup_timeout_ms": {
          "description": "Time limit for EDT startup until the prompt is ready, in milliseconds.",
          "format": "uint64",
          "minimum": 1,
          "type": "integer"
        },
        "version": {
          "description": "Optional EDT version hint used for auto-discovery.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "EnterpriseToolSchema": {
      "additionalProperties": false,
      "properties": {
        "additional-launch-keys": {
          "description": "Additional command-line keys appended to enterprise client launches.",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "ExecutionTimeoutsSchema": {
      "additionalProperties": false,
      "properties": {
        "run_ms": {
          "description": "Main execution timeout in milliseconds.",
          "format": "uint64",
          "minimum": 1,
          "type": [
            "integer",
            "null"
          ]
        },
        "startup_ms": {
          "description": "Startup timeout in milliseconds.",
          "format": "uint64",
          "minimum": 1,
          "type": [
            "integer",
            "null"
          ]
        },
        "total_ms": {
          "description": "Total execution timeout in milliseconds.",
          "format": "uint64",
          "minimum": 1,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "InfobaseDbmsSchema": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "description": "DBMS kind passed to `ibcmd --dbms`.",
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "description": "Physical database name passed to `ibcmd --database-name`.",
          "type": [
            "string",
            "null"
          ]
        },
        "password": {
          "description": "Optional DBMS password passed to `ibcmd --database-password`.",
          "type": [
            "string",
            "null"
          ]
        },
        "server": {
          "description": "DBMS server passed to `ibcmd --database-server`.",
          "type": [
            "string",
            "null"
          ]
        },
        "user": {
          "description": "Optional DBMS user passed to `ibcmd --database-user`.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "InfobaseSchema": {
      "additionalProperties": false,
      "properties": {
        "connection": {
          "description": "1C infobase connection string without embedded user or password.",
          "type": "string"
        },
        "dbms": {
          "anyOf": [
            {
              "$ref": "#/$defs/InfobaseDbmsSchema"
            },
            {
              "type": "null"
            }
          ],
          "description": "Optional DBMS settings for server-based infobases."
        },
        "password": {
          "description": "Optional infobase password passed to platform utilities.",
          "type": [
            "string",
            "null"
          ]
        },
        "unlock_code": {
          "description": "Optional unlock code. Non-empty value is propagated as `/UC <value>` to DESIGNER;\nempty string means no unlock code and `/UC` is not passed. Masked in command logs.",
          "type": [
            "string",
            "null"
          ]
        },
        "user": {
          "description": "Optional infobase user name passed to platform utilities.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "connection"
      ],
      "type": "object"
    },
    "McpExecutionSchema": {
      "additionalProperties": false,
      "properties": {
        "max_concurrent_calls": {
          "description": "Maximum number of MCP calls allowed to execute concurrently.",
          "format": "uint",
          "minimum": 1,
          "type": "integer"
        },
        "shutdown_grace_period_secs": {
          "description": "Grace period for shutdown drain in seconds.",
          "format": "uint64",
          "minimum": 1,
          "type": "integer"
        }
      },
      "type": "object"
    },
    "McpHttpSchema": {
      "additionalProperties": false,
      "properties": {
        "bind_address": {
          "description": "Socket address for the MCP HTTP listener.",
          "type": "string"
        },
        "idle_ttl_secs": {
          "description": "Idle HTTP session eviction timeout in seconds.",
          "format": "uint64",
          "minimum": 1,
          "type": "integer"
        },
        "max_sessions": {
          "description": "Maximum number of tracked HTTP sessions.",
          "format": "uint",
          "minimum": 1,
          "type": "integer"
        },
        "path": {
          "description": "URL path that serves MCP HTTP requests.",
          "type": "string"
        },
        "stateful_sessions": {
          "description": "Whether MCP HTTP sessions keep state across requests.",
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "McpSchema": {
      "additionalProperties": false,
      "properties": {
        "execution": {
          "$ref": "#/$defs/McpExecutionSchema",
          "description": "Shared execution limits for MCP calls."
        },
        "http": {
          "$ref": "#/$defs/McpHttpSchema",
          "description": "MCP HTTP transport settings."
        }
      },
      "type": "object"
    },
    "PlatformToolSchema": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "description": "Platform binary, installation `bin` directory, or platform root discovery hint.",
          "type": [
            "string",
            "null"
          ]
        },
        "version": {
          "description": "Platform version requirement used for discovery.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "SourceFormatSchema": {
      "enum": [
        "DESIGNER",
        "EDT"
      ],
      "type": "string"
    },
    "SourceSetPurposeSchema": {
      "enum": [
        "CONFIGURATION",
        "EXTENSION",
        "EXTERNAL_DATA_PROCESSORS",
        "EXTERNAL_REPORTS"
      ],
      "type": "string"
    },
    "SourceSetSchema": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "description": "Source-set name used by CLI filters and diagnostics.",
          "type": "string"
        },
        "path": {
          "description": "Source path relative to the primary config directory or an EDT project path.",
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/SourceSetPurposeSchema",
          "description": "Source-set type: configuration, extension, external data processors, or external reports."
        }
      },
      "required": [
        "name",
        "type",
        "path"
      ],
      "type": "object"
    },
    "TestsSchema": {
      "additionalProperties": false,
      "properties": {
        "execution_timeout_seconds": {
          "description": "Default test execution timeout in seconds.",
          "format": "uint64",
          "maximum": 86400,
          "minimum": 1,
          "type": "integer"
        },
        "va": {
          "$ref": "#/$defs/VanessaTestSchema",
          "description": "Vanessa Automation test runner settings."
        },
        "yaxunit": {
          "$ref": "#/$defs/YaxunitTestSchema",
          "description": "YAxUnit test runner settings."
        }
      },
      "type": "object"
    },
    "ToolExtensionArtifactSchema": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "description": "Path to a `.cfe` extension artifact.",
          "type": "string"
        }
      },
      "required": [
        "path"
      ],
      "type": "object"
    },
    "ToolExtensionSchema": {
      "additionalProperties": false,
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "artifact": {
              "type": "null"
            },
            "name": {
              "type": "string"
            },
            "source": {
              "$ref": "#/$defs/ToolExtensionSourceSchema"
            }
          },
          "required": [
            "name",
            "source"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "artifact": {
              "$ref": "#/$defs/ToolExtensionArtifactSchema"
            },
            "name": {
              "type": "string"
            },
            "source": {
              "type": "null"
            }
          },
          "required": [
            "name",
            "artifact"
          ],
          "type": "object"
        }
      ],
      "properties": {
        "artifact": {
          "anyOf": [
            {
              "$ref": "#/$defs/ToolExtensionArtifactSchema",
              "description": "Artifact-backed `.cfe` extension input."
            },
            {
              "type": "null"
            }
          ],
          "description": "Artifact-backed `.cfe` extension input."
        },
        "name": {
          "description": "Extension name in the target infobase.",
          "type": "string"
        },
        "source": {
          "anyOf": [
            {
              "$ref": "#/$defs/ToolExtensionSourceSchema",
              "description": "Source-backed extension input."
            },
            {
              "type": "null"
            }
          ],
          "description": "Source-backed extension input."
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "ToolExtensionSourceSchema": {
      "additionalProperties": false,
      "properties": {
        "format": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceFormatSchema"
            },
            {
              "type": "null"
            }
          ],
          "description": "Optional source format; when omitted, the project-level format is used."
        },
        "path": {
          "description": "Path to extension sources.",
          "type": "string"
        }
      },
      "required": [
        "path"
      ],
      "type": "object"
    },
    "ToolsSchema": {
      "additionalProperties": false,
      "properties": {
        "client_mcp": {
          "$ref": "#/$defs/ClientMcpToolSchema",
          "description": "onec-client-mcp tool settings."
        },
        "edt_cli": {
          "$ref": "#/$defs/EdtCliSchema",
          "description": "EDT CLI discovery and execution settings."
        },
        "enterprise": {
          "$ref": "#/$defs/EnterpriseToolSchema",
          "description": "Enterprise client launch settings."
        },
        "platform": {
          "$ref": "#/$defs/PlatformToolSchema",
          "description": "Platform executable discovery settings."
        },
        "va": {
          "$ref": "#/$defs/VanessaToolSchema",
          "description": "Vanessa Automation tool settings."
        }
      },
      "type": "object"
    },
    "VanessaProfileSchema": {
      "additionalProperties": false,
      "properties": {
        "feature_path": {
          "description": "Feature file or directory used by this Vanessa profile.",
          "type": [
            "string",
            "null"
          ]
        },
        "features_to_run": {
          "description": "Explicit feature files or directories to run.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "filter_tags": {
          "description": "Tags included by this Vanessa profile.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "ignore_tags": {
          "description": "Tags ignored by this Vanessa profile.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "scenario_filter": {
          "description": "Scenario name filters used by this Vanessa profile.",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "VanessaTestSchema": {
      "additionalProperties": false,
      "properties": {
        "fail_fast": {
          "description": "Stop the Vanessa test run after the first failure.",
          "type": "boolean"
        },
        "params_path": {
          "description": "Path to generated Vanessa parameters.",
          "type": [
            "string",
            "null"
          ]
        },
        "profile": {
          "description": "Vanessa profile name to use by default.",
          "type": [
            "string",
            "null"
          ]
        },
        "profiles": {
          "additionalProperties": {
            "$ref": "#/$defs/VanessaProfileSchema"
          },
          "description": "Named Vanessa profiles available to CLI and MCP test runs.",
          "type": "object"
        },
        "timeouts": {
          "$ref": "#/$defs/ExecutionTimeoutsSchema",
          "description": "Vanessa startup, run, and total timeout overrides."
        }
      },
      "type": "object"
    },
    "VanessaToolSchema": {
      "additionalProperties": false,
      "properties": {
        "epf_path": {
          "description": "Path to the Vanessa Automation external data processor.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "YaxunitTestSchema": {
      "additionalProperties": false,
      "properties": {
        "timeouts": {
          "$ref": "#/$defs/ExecutionTimeoutsSchema",
          "description": "YAxUnit startup, run, and total timeout overrides."
        }
      },
      "type": "object"
    }
  },
  "$id": "https://raw.githubusercontent.com/alkoleft/v8-runner-rust/master/docs/schemas/v8project.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "build": {
      "$ref": "#/$defs/BuildSchema",
      "description": "Build pipeline settings."
    },
    "builder": {
      "$ref": "#/$defs/BuilderBackendSchema",
      "description": "Backend used for build/load operations."
    },
    "execution_timeout": {
      "description": "Global execution budget for public CLI and MCP commands in milliseconds.",
      "format": "uint64",
      "maximum": 86400000,
      "minimum": 1,
      "type": "integer"
    },
    "format": {
      "$ref": "#/$defs/SourceFormatSchema",
      "description": "Source format used by project source sets when a nested source does not override it."
    },
    "infobase": {
      "$ref": "#/$defs/InfobaseSchema",
      "description": "Target infobase connection, credentials, and optional DBMS settings."
    },
    "mcp": {
      "$ref": "#/$defs/McpSchema",
      "description": "MCP server transport and execution settings."
    },
    "source-set": {
      "description": "Project source sets to build, test, dump, or materialize.",
      "items": {
        "$ref": "#/$defs/SourceSetSchema"
      },
      "type": "array"
    },
    "tests": {
      "$ref": "#/$defs/TestsSchema",
      "description": "Test runner defaults and profile settings."
    },
    "tools": {
      "$ref": "#/$defs/ToolsSchema",
      "description": "External tool discovery and launch settings."
    },
    "workPath": {
      "description": "Working directory for generated state, logs, temporary files, and hash storages.",
      "type": "string"
    }
  },
  "required": [
    "workPath",
    "infobase",
    "source-set"
  ],
  "title": "MainConfigSchema",
  "type": "object"
}
